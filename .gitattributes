# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for shell/cross-platform files
*.sh        text eol=lf
*.bash      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf

# Force CRLF for Windows-specific files
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.sln       text eol=crlf
*.csproj    text eol=crlf
*.vbproj    text eol=crlf
*.fsproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf
*.wixproj   text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.msi       binary
*.exe       binary
*.dll       binary
*.pfx       binary
*.snk       binary
*.keytab    binary
