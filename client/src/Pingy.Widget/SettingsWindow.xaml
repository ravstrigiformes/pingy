<Window x:Class="Pingy.Widget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SETTINGS"
        Width="440" Height="416"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        TextOptions.TextFormattingMode="Display"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="Cyan">#FF00F0FF</Color>
        <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource Cyan}"/>
        <SolidColorBrush x:Key="DimBrush" Color="#FF5C6F94"/>
        <SolidColorBrush x:Key="HintBrush" Color="#FF8C9EBF"/>
        <SolidColorBrush x:Key="LabelBrush" Color="#FFB6C8E4"/>
        <SolidColorBrush x:Key="BrightBrush" Color="#FFD9F4FF"/>
        <SolidColorBrush x:Key="VoidBrush" Color="#FF050810"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0B1120"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource BrightBrush}"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="#3A00F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Padding" Value="16,12,16,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Checkbox: cyan label, default glyph (proven-safe — no custom template). -->
        <Style x:Key="SettingCheck" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource BrightBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Stepper button (− / +) — simple Border + TextBlock template. -->
        <Style x:Key="StepButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#220B1326"
                                BorderBrush="#5500F0FF" BorderThickness="1">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="{TemplateBinding FontSize}" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3300F0FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action (DONE) — copied from the proven AddTargetWindow style. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                BorderBrush="{StaticResource CyanBrush}"
                                BorderThickness="1"
                                Background="#2200F0FF"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource Cyan}" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontWeight="Bold"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5500F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource CyanBrush}" BorderThickness="1" Background="{StaticResource VoidBrush}">
        <Border.Effect>
            <DropShadowEffect Color="{StaticResource Cyan}" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="19" FontWeight="Bold" Foreground="{StaticResource CyanBrush}" Margin="0,-2,9,0"/>
                    <TextBlock Text="SETTINGS" FontSize="17" FontWeight="Bold" Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource Cyan}" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="30" Height="26" Background="Transparent"
                        BorderBrush="{StaticResource DimBrush}" BorderThickness="1"
                        Foreground="{StaticResource DimBrush}" Cursor="Hand"
                        IsTabStop="False" Click="Close_Click" ToolTip="Close"/>
            </Grid>

            <!-- ===== SECTIONS ===== -->
            <StackPanel Grid.Row="1">

                <!-- APPEARANCE -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="3" Height="14" Fill="{StaticResource CyanBrush}" Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="APPEARANCE"/>
                        </StackPanel>
                        <Border Height="1" Background="#2600F0FF" Margin="0,8,0,14"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="OPACITY"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource StepButton}" Content="−"
                                        Click="OpacityDown_Click" ToolTip="Less opaque"/>
                                <TextBlock Style="{StaticResource RowValue}" Margin="6,0"
                                           Text="{Binding WindowOpacity, StringFormat={}{0:P0}}"/>
                                <Button Style="{StaticResource StepButton}" Content="+"
                                        Click="OpacityUp_Click" ToolTip="More opaque"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="ZOOM"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource StepButton}" Content="−"
                                        Click="ZoomDown_Click" ToolTip="Smaller"/>
                                <TextBlock Style="{StaticResource RowValue}" Margin="6,0"
                                           Text="{Binding Zoom, StringFormat={}{0:P0}}"/>
                                <Button Style="{StaticResource StepButton}" Content="+"
                                        Click="ZoomUp_Click" ToolTip="Larger"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- BEHAVIOUR -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="3" Height="14" Fill="{StaticResource CyanBrush}" Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="BEHAVIOUR"/>
                        </StackPanel>
                        <Border Height="1" Background="#2600F0FF" Margin="0,8,0,14"/>

                        <CheckBox Style="{StaticResource SettingCheck}" Margin="0,0,0,4"
                                  Content="Sparkline chart"
                                  IsChecked="{Binding AnimationsEnabled, Mode=TwoWay}"/>
                        <TextBlock FontSize="10" Foreground="{StaticResource HintBrush}" Margin="20,0,0,12"
                                   Text="Animated latency line. Off = a static dot strip."/>

                        <CheckBox Style="{StaticResource SettingCheck}" Margin="0,0,0,4"
                                  Content="Always on top"
                                  IsChecked="{Binding IsTopmost, Mode=TwoWay}"/>
                        <TextBlock FontSize="10" Foreground="{StaticResource HintBrush}" Margin="20,0,0,0"
                                   Text="Keep the widget above other windows."/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ===== ACTIONS ===== -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource HintBrush}"
                           Text="Changes apply live and save automatically."/>
                <Button Grid.Column="1" Content="DONE" Style="{StaticResource PrimaryButton}"
                        Click="Close_Click" IsDefault="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
