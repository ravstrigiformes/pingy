<Window x:Class="Pingy.Widget.MainWindowV2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pingy.Widget.ViewModels"
        xmlns:cv="clr-namespace:Pingy.Widget.Converters"
        xmlns:ctl="clr-namespace:Pingy.Widget.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="PINGY // V2"
        Icon="Assets/pingy.ico"
        Width="900" Height="560"
        MinWidth="360" MinHeight="280"
        Topmost="{Binding IsTopmost}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Opacity="{Binding Value, ElementName=OpacitySlider, Mode=OneWay}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="8"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="BgVoid">#FF050810</Color>
        <Color x:Key="Cyan">#FF00F0FF</Color>
        <Color x:Key="Magenta">#FFFF2E63</Color>
        <Color x:Key="Yellow">#FFFFE600</Color>
        <Color x:Key="TextDim">#FF5C6F94</Color>
        <Color x:Key="TextBright">#FFD9F4FF</Color>

        <SolidColorBrush x:Key="BgVoidBrush" Color="{StaticResource BgVoid}"/>
        <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource Cyan}"/>
        <SolidColorBrush x:Key="MagentaBrush" Color="{StaticResource Magenta}"/>
        <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource Yellow}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>
        <SolidColorBrush x:Key="TextBrightBrush" Color="{StaticResource TextBright}"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <cv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        </Style>

        <Style x:Key="GlowText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{StaticResource Cyan}" BlurRadius="6" ShadowDepth="0" Opacity="0.85"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Generic chrome (regular Button) -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="MinWidth" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1500F0FF"/>
                                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MagentaBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource MagentaBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Icon ToggleButton (PIN, GRAPH) -->
        <Style x:Key="IconToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse x:Name="ActiveDot"
                                         Width="3" Height="3"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,2,2,0"
                                         Visibility="Collapsed"
                                         Fill="{StaticResource CyanBrush}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1500F0FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3300F0FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                                <Setter TargetName="ActiveDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepperBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="Background" Value="#220B1326"/>
            <Setter Property="BorderBrush" Value="#5500F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource CyanBrush}"/>
        </Style>

        <Style x:Key="CyberSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Rectangle Height="2" Fill="#33FFFFFF"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Height="2" Fill="{StaticResource CyanBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Polygon Points="0,0 10,0 5,10"
                                                         Fill="{StaticResource CyanBrush}"
                                                         Width="10" Height="10"
                                                         Margin="0,2,0,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TagPill" TargetType="Border">
            <Setter Property="BorderBrush" Value="#5500F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1500F0FF"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="Margin" Value="0,2,4,0"/>
        </Style>

        <!-- Port pill: tiny status dot + :port[/label]. Border tint follows the per-port StateBrush. -->
        <Style x:Key="PortPill" TargetType="Border">
            <Setter Property="BorderBrush" Value="#5500F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#100B1326"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,2,4,0"/>
        </Style>

        <Style x:Key="FilterChip" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" BorderBrush="{StaticResource TextDimBrush}" BorderThickness="1" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" Foreground="{StaticResource TextDimBrush}" FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#3300F0FF"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberComboItem" TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3300F0FF"/>
                                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberCombo" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="Background" Value="#220B1326"/>
            <Setter Property="BorderBrush" Value="#5500F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CyberComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="OuterBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1"
                                                      Data="M 0,0 L 8,0 L 4,5 Z"
                                                      Fill="{StaticResource CyanBrush}"
                                                      Width="8" Height="5"
                                                      Margin="6,0,8,0"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                                <Setter TargetName="OuterBd" Property="Background" Value="#330B1326"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="6,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="{StaticResource CyanBrush}"
                                              TextElement.FontFamily="Cascadia Mono, Consolas"
                                              TextElement.FontSize="10"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#FF050810"
                                        BorderBrush="{StaticResource CyanBrush}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer Margin="2" MaxHeight="240">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact target-card container for the responsive grid (gaps come from the panel). -->
        <Style x:Key="TargetCardBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#3300F0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#080B16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#10101D2A"/>
                    <Setter Property="BorderBrush" Value="#7700F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>

    <!-- ================ FULL MODE ================ -->
    <Grid Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}">

        <!-- Chrome layer: outer magenta shadow, inner cyan border, both sized to the window via SizeChanged. -->
        <Path x:Name="OuterChrome"
              Stroke="{StaticResource MagentaBrush}"
              StrokeThickness="1"
              StrokeLineJoin="Miter"
              SnapsToDevicePixels="True">
            <Path.Effect><DropShadowEffect Color="{StaticResource Magenta}" BlurRadius="14" ShadowDepth="0" Opacity="0.45"/></Path.Effect>
        </Path>

        <Path x:Name="InnerChrome"
              Stroke="{StaticResource CyanBrush}"
              StrokeThickness="1"
              SnapsToDevicePixels="True">
            <Path.Fill><SolidColorBrush Color="{StaticResource BgVoid}"/></Path.Fill>
            <Path.Effect>
                <DropShadowEffect x:Name="BorderGlow"
                                  Color="{StaticResource Cyan}"
                                  BlurRadius="8"
                                  ShadowDepth="0"
                                  Opacity="0.55"/>
            </Path.Effect>
        </Path>

        <!-- background grid -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True" Margin="3,3,3,3">
            <Canvas.OpacityMask>
                <RadialGradientBrush>
                    <GradientStop Color="#FF000000" Offset="0"/>
                    <GradientStop Color="#33000000" Offset="1"/>
                </RadialGradientBrush>
            </Canvas.OpacityMask>
            <Canvas.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen><Pen Brush="#1500F0FF" Thickness="1"/></GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="0,0" EndPoint="24,0"/>
                                    <LineGeometry StartPoint="0,0" EndPoint="0,24"/>
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Canvas.Background>
        </Canvas>

        <!-- Scanline (animations + not interacting). Paused during window drag/resize. -->
        <Canvas x:Name="ScanlineCanvas" IsHitTestVisible="False" ClipToBounds="True" Margin="3,3,3,3"
                Visibility="{Binding ScanlineActive, Converter={StaticResource BoolToVis}}">
            <Rectangle x:Name="Scanline" Height="2" Opacity="0.45">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0000F0FF" Offset="0"/>
                        <GradientStop Color="#FF00F0FF" Offset="0.5"/>
                        <GradientStop Color="#0000F0FF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform><TranslateTransform x:Name="ScanlineXf" Y="-4"/></Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <!-- CONTENT (scaled by Zoom via LayoutTransform on inner grid) -->
        <Grid Margin="14,12,14,10">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
            </Grid.LayoutTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: TITLE BAR -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="9" Height="9"
                                 Fill="{Binding HealthBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="{Binding HealthLabel}"/>
                        <TextBlock Text="PINGY" FontSize="18" FontWeight="Bold" Style="{StaticResource GlowText}"/>
                        <TextBlock Text="//" FontSize="18" Margin="6,0,6,0" Foreground="{StaticResource TextDimBrush}" FontWeight="Bold"/>
                        <TextBlock Text="NETWORK MONITOR" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrightBrush}"/>
                        <TextBlock Text=".v2" FontSize="10" Foreground="{StaticResource MagentaBrush}" VerticalAlignment="Top" Margin="2,2,0,0"/>
                        <TextBlock Text=" :: " FontSize="11" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" Margin="6,4,0,0"/>
                        <TextBlock Text="{Binding HealthLabel}" FontSize="11" Foreground="{Binding HealthBrush}" VerticalAlignment="Center" Margin="0,4,0,0" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <ToggleButton Style="{StaticResource IconToggle}"
                                      IsChecked="{Binding AnimationsEnabled, Mode=TwoWay}"
                                      ToolTip="Animations (sparkline + scanline). Off = static dots.">
                            <TextBlock Text="∿" FontSize="14" FontWeight="Bold"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource IconToggle}"
                                      IsChecked="{Binding IsTopmost, Mode=TwoWay}"
                                      ToolTip="Always on top">
                            <TextBlock Text="⌖" FontSize="14"/>
                        </ToggleButton>
                        <!-- Dedicated mini-mode toggle (separate from maximize) -->
                        <Button Style="{StaticResource ChromeButton}" Content="▭" Click="ModeToggle_Click" ToolTip="Collapse to mini" FontSize="12"/>
                        <!-- Standard Windows cluster: minimize | maximize-restore | close -->
                        <Button Style="{StaticResource ChromeButton}" Content="—" Click="MinimizeButton_Click" ToolTip="Minimize"/>
                        <Button x:Name="MaxRestoreBtn" Style="{StaticResource ChromeButton}" Content="▢" Click="MaxRestoreButton_Click" ToolTip="Maximize"/>
                        <Button Style="{StaticResource CloseButton}" Content="✕" Click="CloseButton_Click" Margin="0" ToolTip="Close"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 1: PRIMARY TOOLBAR -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource AccentButton}" Content="+ ADD TARGET" Click="AddTargetButton_Click" Margin="0,0,12,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource LabelText}" Text="INTERVAL " VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ChromeButton}" Content="−" Click="IntervalDecrease_Click" MinWidth="22" Margin="4,0,2,0"/>
                        <TextBox x:Name="IntervalBox" Style="{StaticResource StepperBox}"
                                 Text="{Binding IntervalSeconds, UpdateSourceTrigger=LostFocus, Mode=TwoWay, FallbackValue=5}"
                                 PreviewTextInput="IntervalBox_PreviewTextInput"
                                 KeyDown="IntervalBox_KeyDown"/>
                        <Button Style="{StaticResource ChromeButton}" Content="+" Click="IntervalIncrease_Click" MinWidth="22" Margin="2,0,4,0"/>
                        <TextBlock Style="{StaticResource LabelText}" Text="s [1–300]" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Zoom stepper -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelText}" Text="ZOOM " VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ChromeButton}" Content="−" Click="ZoomOut_Click" MinWidth="22" ToolTip="Zoom out"/>
                        <TextBlock Text="{Binding Zoom, StringFormat={}{0:P0}}"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CyanBrush}"
                                   MinWidth="40"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource ChromeButton}" Content="+" Click="ZoomIn_Click" MinWidth="22" ToolTip="Zoom in"/>
                        <Button Style="{StaticResource ChromeButton}" Content="⌂" Click="ZoomReset_Click" MinWidth="22" Margin="2,0,0,0" ToolTip="Reset zoom to 100%"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock Style="{StaticResource LabelText}" Text="OPACITY" HorizontalAlignment="Center"/>
                        <Slider x:Name="OpacitySlider" Style="{StaticResource CyberSlider}" Minimum="0.3" Maximum="1.0" Value="0.95" Width="110" Height="14"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 2: FILTER + SORT BAR -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="FILTER " VerticalAlignment="Top" Margin="0,4,4,0"/>
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding FilterChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TagChipViewModel}">
                                <ToggleButton Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource FilterChip}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Column="2" Style="{StaticResource LabelText}" Text="SORT " VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox Grid.Column="3"
                              Style="{StaticResource CyberCombo}"
                              ItemsSource="{Binding SortChoices}"
                              SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                              MinWidth="180"/>
                </Grid>

                <!-- ROW 3: divider -->
                <Border Grid.Row="3" Height="1" Margin="0,8,0,8" BorderThickness="0,0,0,1" BorderBrush="#3300F0FF"/>

                <!-- ROW 4: TARGETS LIST (responsive grid — fills width, cards stretch, min 280px per card) -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding TargetsView}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- WPF measures in device-independent (logical) pixels at 96 DPI.
                                       A 1920x1080 display at 150% DPI is 1280x720 LOGICAL pixels.
                                       MinItemWidth=220 → ~2-3 cols at half-screen, ~5-6 cols maximized
                                       on a 150% DPI display, scales sensibly across other DPIs too. -->
                                <ctl:ResponsiveWrapPanel MinItemWidth="220" HorizontalGap="8" VerticalGap="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TargetStatusViewModel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Drop indicators: vertical pipes on left/right edges (column-flow insert) -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="3"
                                            Margin="-5,0,0,0"
                                            Background="{StaticResource CyanBrush}"
                                            Visibility="{Binding IsDropBefore, Converter={StaticResource BoolToVis}}"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="3"
                                            Margin="0,0,-5,0"
                                            Background="{StaticResource CyanBrush}"
                                            Visibility="{Binding IsDropAfter, Converter={StaticResource BoolToVis}}"/>

                                    <Border Style="{StaticResource TargetCardBorder}"
                                            MouseLeftButtonUp="TargetRow_MouseLeftButtonUp"
                                            AllowDrop="True"
                                            DragOver="Row_DragOver"
                                            Drop="Row_Drop">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Top accent bar (uses AccentBrush — worst-in-window color) -->
                                            <Rectangle Grid.Row="0" Height="2" Fill="{Binding AccentBrush}"/>

                                            <!-- Header: drag handle | diamond | label/host | latency | badge -->
                                            <Grid Grid.Row="1" Margin="8,6,8,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Drag handle (small, visible only when reorder allowed) -->
                                                <Border Grid.Column="0"
                                                        Width="14" Height="20"
                                                        Background="Transparent"
                                                        Cursor="SizeAll"
                                                        Tag="DragHandle"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,4,0"
                                                        AllowDrop="True"
                                                        PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                                        DragOver="Row_DragOver"
                                                        Drop="Row_Drop"
                                                        ToolTip="Drag to reorder"
                                                        Visibility="{Binding DataContext.CanReorder, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="⋮⋮"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"/>
                                                </Border>

                                                <!-- Diamond — uses AccentBrush (worst-in-window) -->
                                                <Polygon Grid.Column="1"
                                                         Points="6,0 12,6 6,12 0,6"
                                                         Fill="{Binding AccentBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"/>

                                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="{StaticResource TextBrightBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Host}"
                                                               FontSize="10"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               Foreground="{StaticResource CyanBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Opacity="0.85"/>
                                                </StackPanel>

                                                <!-- Right side: latency + status badge stacked -->
                                                <StackPanel Grid.Column="3" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding RttDisplay}"
                                                               FontSize="15" FontWeight="Bold"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{Binding AccentBrush}"/>
                                                    <Border BorderBrush="{Binding StateBrush}"
                                                            BorderThickness="1"
                                                            Padding="5,0"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding StateBadge}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding StateBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Bottom: tags + ports + sparkline / dot strip -->
                                            <Grid Grid.Row="2" Margin="8,0,8,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <ItemsControl Grid.Row="0" ItemsSource="{Binding Tags}" Margin="0,0,0,4">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type sys:String}">
                                                            <Border Style="{StaticResource TagPill}">
                                                                <TextBlock Text="{Binding}" FontSize="9" Foreground="{StaticResource CyanBrush}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Port pills: tiny status dot + :port[/label] + state badge. Tri-tone:
                                                     cyan OK / amber DEGR (L7 failing) / magenta DOWN. Tooltip shows L4+L7 detail. -->
                                                <ItemsControl Grid.Row="1"
                                                              ItemsSource="{Binding Ports}"
                                                              Margin="0,0,0,4"
                                                              Visibility="{Binding HasPorts, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:PortStatusViewModel}">
                                                            <Border Style="{StaticResource PortPill}"
                                                                    BorderBrush="{Binding StateBrush}"
                                                                    ToolTip="{Binding Tooltip}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="6" Height="6"
                                                                             Fill="{Binding StateBrush}"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,4,0"/>
                                                                    <TextBlock Text="{Binding Display}"
                                                                               FontSize="9"
                                                                               FontFamily="Cascadia Mono, Consolas"
                                                                               Foreground="{Binding StateBrush}"/>
                                                                    <TextBlock Text="{Binding StateBadge}"
                                                                               FontSize="8"
                                                                               FontWeight="Bold"
                                                                               FontFamily="Cascadia Mono, Consolas"
                                                                               Foreground="{Binding StateBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="5,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- VIZ: polyline (animations ON) -->
                                                <Grid Grid.Row="2" Height="28"
                                                      Visibility="{Binding DataContext.AnimationsEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                    <Border BorderBrush="#1500F0FF" BorderThickness="1" Background="#080B16"/>
                                                    <Line Stroke="#3300F0FF" StrokeThickness="0.5" StrokeDashArray="2,4" X1="0" X2="600" Y1="14" Y2="14" Stretch="Fill" HorizontalAlignment="Stretch"/>
                                                    <Polyline Points="{Binding LatencyPolyline}" Stroke="{Binding AccentBrush}" StrokeThickness="1.5" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                                </Grid>

                                                <!-- VIZ: dot strip (animations OFF) -->
                                                <ItemsControl Grid.Row="2"
                                                              ItemsSource="{Binding RecentDots}"
                                                              Height="10"
                                                              HorizontalAlignment="Stretch"
                                                              Visibility="{Binding DataContext.AnimationsEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvBoolToVis}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1" Columns="60" HorizontalAlignment="Stretch"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Ellipse HorizontalAlignment="Stretch"
                                                                     VerticalAlignment="Center"
                                                                     Height="6"
                                                                     Margin="0.5,0"
                                                                     Fill="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ROW 5: STATUS BAR -->
                <Grid Grid.Row="5" Margin="0,6,0,0">
                    <Border Background="#160B1326" BorderBrush="#3300F0FF" BorderThickness="1,1,1,0" Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource LabelText}" Text="HEALTH:"/>
                                <TextBlock FontSize="9" Foreground="{Binding HealthBrush}" Text="{Binding HealthLabel, StringFormat=' {0}  '}"/>
                                <TextBlock Style="{StaticResource LabelText}" Text="| TRACE:"/>
                                <TextBlock FontSize="9" Foreground="{StaticResource MagentaBrush}" Text=" LIVE  "/>
                                <TextBlock Style="{StaticResource LabelText}" Text="| LINK:"/>
                                <TextBlock FontSize="9" Foreground="{StaticResource YellowBrush}" Text=" LOCAL"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" FontSize="9" Foreground="{StaticResource TextDimBrush}" Text="{Binding StatusLine}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

    <!-- ================ MINI MODE ================ -->
    <!-- No Viewbox: content fills the window naturally so snap-right can stretch full height
         without distorting/centering the design. Font sizes stay at their original "small mini" values. -->
    <Grid Visibility="{Binding IsMiniMode, Converter={StaticResource BoolToVis}}">
        <Border BorderBrush="{StaticResource CyanBrush}" BorderThickness="1" Background="{StaticResource BgVoidBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#221E2A4D" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                            <Ellipse Width="6" Height="6" Fill="{Binding HealthBrush}" Margin="0,0,4,0" ToolTip="{Binding HealthLabel}"/>
                            <TextBlock Text="pingy" FontSize="10" FontWeight="Bold" Foreground="{StaticResource CyanBrush}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource IconToggle}"
                                      IsChecked="{Binding ShowMiniDots, Mode=TwoWay}"
                                      Width="22" Height="18" Margin="0,0,2,0"
                                      ToolTip="Show dots strip">
                            <TextBlock Text="∿" FontSize="11" FontWeight="Bold"/>
                        </ToggleButton>
                        <Button Grid.Column="2" Style="{StaticResource ChromeButton}" Content="↻" Click="MiniCycler_Click" Width="22" Height="18" Margin="0,0,2,0" Padding="0" FontSize="11" ToolTip="Cycle display field (host / label)"/>
                        <!-- Snap to right edge, full height, keep mini width -->
                        <Button Grid.Column="3" Style="{StaticResource ChromeButton}" Content="⇥" Click="MiniSnapRight_Click" Width="22" Height="18" Margin="0,0,2,0" Padding="0" FontSize="11" ToolTip="Snap to right edge (full height)"/>
                        <Button Grid.Column="4" Style="{StaticResource ChromeButton}" Content="▣" Click="ModeToggle_Click" Width="22" Height="18" Margin="0,0,2,0" Padding="0" FontSize="10" ToolTip="Restore to full"/>
                        <Button Grid.Column="5" Style="{StaticResource CloseButton}" Content="✕" Click="CloseButton_Click" Width="22" Height="18" Margin="0,0,2,0" Padding="0" FontSize="9"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Padding="0,2,0,0">
                        <ItemsControl ItemsSource="{Binding TargetsView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TargetStatusViewModel}">
                                    <Border BorderBrush="#1F00F0FF" BorderThickness="0,0,0,1" Margin="4,1,4,1" Padding="2,1,2,5">
                                    <StackPanel Orientation="Vertical">
                                        <Grid Height="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="6" Height="6" Fill="{Binding AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       FontSize="10"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextBrightBrush}"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.ToolTip>
                                                    <ToolTip><TextBlock><Run Text="{Binding Label}"/><Run Text=" — "/><Run Text="{Binding Host}"/></TextBlock></ToolTip>
                                                </TextBlock.ToolTip>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Host}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.MiniDisplayField, RelativeSource={RelativeSource AncestorType=Window}}" Value="Label">
                                                                <Setter Property="Text" Value="{Binding Label}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Text="{Binding RttDisplay}" FontSize="9" FontFamily="Cascadia Mono, Consolas" FontWeight="Bold" Foreground="{Binding AccentBrush}" VerticalAlignment="Center" Margin="4,0,2,0"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding RecentDotsMini}"
                                                      Height="6"
                                                      Margin="0,0,0,0"
                                                      HorizontalAlignment="Stretch"
                                                      Visibility="{Binding DataContext.ShowMiniDots, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1" Columns="30" HorizontalAlignment="Stretch"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse HorizontalAlignment="Stretch"
                                                             VerticalAlignment="Center"
                                                             Height="4"
                                                             Margin="0.25,0"
                                                             Fill="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
    </Grid>

    </Grid>
</Window>
