<Window x:Class="Pingy.Widget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pingy.Widget.ViewModels"
        Title="pingy"
        Height="320" Width="540"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Opacity="{Binding Value, ElementName=OpacitySlider, Mode=OneWay}"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0F172A" CornerRadius="8" BorderBrush="#1E293B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title/drag bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="14,10,0,8">
                    <TextBlock Text="pingy" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="walking skeleton — drag to move" FontSize="10" Foreground="#64748B"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="opacity" FontSize="10" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="OpacitySlider"
                            Minimum="0.3" Maximum="1.0" Value="0.95"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            Width="120"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource CloseButton}"
                        Margin="0,0,4,0"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Body: target list -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Targets}"
                          Margin="14,4,14,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TargetStatusViewModel}">
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0"
                                     Width="12" Height="12"
                                     VerticalAlignment="Center"
                                     Fill="{Binding StateBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock Text="{Binding Host}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="#64748B"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RttDisplay}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding State}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       FontSize="10"
                                       Foreground="#94A3B8"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="#1E293B"
                    CornerRadius="0,0,7,7"
                    Padding="14,8">
                <TextBlock FontSize="11"
                           Foreground="#94A3B8"
                           Text="{Binding StatusLine}"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
